# ============================================
# Score de Barrio Backend - Configuration
# Copia este archivo como .env y completa los valores
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite)
DATABASE_PATH=./data/scoredebarrio.db

# Blockchain - Mantle Sepolia
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# Relayer Wallet (necesita fondos para pagar gas)
# NUNCA commitear la clave real
RELAYER_PRIVATE_KEY=your_relayer_private_key_here

# Deployed Contracts
MERCHANT_REGISTRY=0x0000000000000000000000000000000000000000
SALES_EVENT_LOG=0x0000000000000000000000000000000000000000

# Sync Configuration
BUCKET_DURATION=900
SYNC_INTERVAL_MS=900000

# Security — generar con: openssl rand -hex 32
API_KEY_SALT=your_random_hex_salt_here
JWT_SECRET=your_random_hex_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# PostgreSQL (Railway / Supabase / etc.)
DATABASE_URL="postgresql://user:password@host:port/dbname"
